const SAMPLE_SNS = [
  { id: 1, category: "official_insta", type: "post",  memo: "新曲MVのオフショット！ #WANIMA #MV #撮影 #ロック", date: "2025-05-20", url: "https://www.instagram.com/p/example1/", images: [], videos: [] },
  { id: 2, category: "kenta_x",        type: "post",  memo: "ツアーリハーサル最高だった！ #KENTA #ツアー #リハーサル", date: "2025-05-18", url: "https://x.com/kenta_wanima/status/example2", images: [], videos: [] },
  { id: 3, category: "official_x",     type: "post",  memo: "ワンマンライブ告知きた！ #WANIMA #ライブ #告知", date: "2025-05-10", url: "", images: [], videos: [] },
  { id: 4, category: "kenta_insta",    type: "story", memo: "スタジオ風景 #KENTA #スタジオ", date: "2025-05-05", url: "", images: [], videos: [] },
