  { id: 1, typeId: "tv",    title: "MUSIC STATION",        date: "2025-05-16", detail: "「Remember」生演奏",   memo: "初のMステ！最高だった #WANIMA #Mステ #TV", url: "", images: [] },
  { id: 2, typeId: "radio", title: "RADIO FISH with WANIMA", date: "2025-04-20", detail: "ゲスト出演・新曲初解禁", memo: "#WANIMA #ラジオ #新曲",                 url: "", images: [] },
