  { id: "nezumi",     label: "ねずみちゃん",     icon: "🐭", color: "#c084fc", description: "ねずみちゃんコンテンツ" },
];
const SAMPLE_FC_ENTRIES = [
  { id: 1, channelId: "kenta_blog", title: "ツアー前日の気持ち", date: "2025-05-30", episode: "", memo: "武道館前夜のブログ。気合い入ってた！ #KENTA #ブログ #武道館", url: "", images: [], groupType: "single" },
  { id: 2, channelId: "radio2",     title: "#42 新曲について語る回", date: "2025-05-15", episode: "42", memo: "新曲の制作秘話がたっぷり！ #ラジオ2 #新曲", url: "", images: [], groupType: "single" },
];



// ── File → base64 helper ─────────────────────────────────────
function readFileAsDataURL(file) {
  return new Promise((resolve) => {
    const reader = new FileReader();
    reader.onload = (e) => resolve(e.target.result);
    reader.readAsDataURL(file);
  });
}
async function filesToDataURLs(files) {
  return Promise.all(Array.from(files).map((f) =>
    readFileAsDataURL(f).then((url) => ({ name: f.name, url }))
  ));
}


// ═══════════════════════════════════════════════════════════════
//  CONSTANTS
// ═══════════════════════════════════════════════════════════════

